@model PetDiverse.Models.AnimalViewModel

@{
    ViewData["Title"] = "Criar animal";
}

<h2>Criar animal</h2>

<hr />
<div class="row">
    <div class="col-md-12">
        <form asp-action="Create" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <!-- Tipo de Animal -->
            <div class="row mb-2">
                <div class="col-md-9">
                    <div class="form-group row">
                        <label asp-for="IdTipoAnimal" class="col-sm-5 control-label">Qual o tipo do animal?</label>
                        <div class="col-sm-7">
                            <select asp-for="IdTipoAnimal" class="form-control" asp-items="ViewBag.IdTipoAnimal">
                                <option value="">Selecione um tipo de animal</option>
                            </select>
                            <span asp-validation-for="IdTipoAnimal" class="text-danger"></span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Nome -->
            <div class="row mb-2">
                <div class="col-md-9">
                    <div class="form-group row">
                        <label asp-for="Nome" class="col-sm-5 control-label"></label>
                        <div class="col-sm-7">
                            <input asp-for="Nome" class="form-control" />
                            <span asp-validation-for="Nome" class="text-danger"></span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Idade + Contagem -->
            <div class="row mb-2">
                <div class="col-md-9">
                    <div class="form-group row">
                        <label asp-for="Idade" class="col-sm-5 control-label"></label>
                        <div class="col-sm-2">
                            <input asp-for="Idade" class="form-control mb-1" />
                            <span asp-validation-for="Idade" class="text-danger"></span>
                        </div>
                        <div class="col-sm-5">
                            <select asp-for="ContagemIdade" class="form-control" asp-items="ViewBag.ContagemIdade">
                                <option value="">Selecione uma contagem de idade</option>
                            </select>
                            <span asp-validation-for="ContagemIdade" class="text-danger"></span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Descrição -->
            <div class="row mb-2">
                <div class="col-md-9">
                    <div class="form-group row">
                        <label asp-for="Descricao" class="col-sm-5 control-label"></label>
                        <div class="col-sm-7">
                            <textarea asp-for="Descricao" class="form-control"> </textarea>
                            <span asp-validation-for="Descricao" class="text-danger"></span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Sexo biológico -->
            <div class="row mb-2">
                <div class="col-md-9">
                    <div class="form-group row">
                        <label asp-for="SexoBiologico" class="col-sm-5 control-label"></label>
                        <div class="col-sm-7">
                            <select asp-for="SexoBiologico" class="form-control" asp-items="ViewBag.SexoBiologico">
                                <option value="">Selecione um sexo biológico</option>
                            </select>
                            <span asp-validation-for="SexoBiologico" class="text-danger"></span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Porte -->
            <div class="row mb-2">
                <div class="col-md-9">
                    <div class="form-group row">
                        <label asp-for="Porte" class="col-sm-5 control-label"></label>
                        <div class="col-sm-7">
                            <select asp-for="Porte" class="form-control" asp-items="ViewBag.PorteAnimal">
                                <option value="">Selecione um porte</option>
                            </select>
                            <span asp-validation-for="Porte" class="text-danger"></span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Raça -->
            <div class="row mb-2">
                <div class="col-md-9">
                    <div class="form-group row">
                        <label asp-for="IdRaca" class="col-sm-5 control-label"></label>
                        <div class="col-sm-7">
                            <select asp-for="IdRaca" class="form-control" asp-items="ViewBag.IdRaca">
                                <option value="">Selecione uma raça</option>
                            </select>
                            <span asp-validation-for="IdRaca" class="text-danger"></span>
                        </div>
                    </div>
                </div>
            </div>


            <!-- Foto -->
            <div class="row mb-2">
                <div class="col-md-9">
                    <div class="form-group row">
                        <label asp-for="Foto" class="col-sm-5 control-label"></label>
                        <div class="col-sm-7">
                            <input asp-for="Foto" class="form-control" type="file" accept="image/jpg,image/jpeg,image/png" />
                            <span asp-validation-for="Foto" class="text-danger"></span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Botões -->
            <div class="form-group mt-2">
                <a asp-action="Index" class="btn btn-cinza">Voltar à lista</a>
                <input type="submit" value="Criar" class="btn btn-roxo" />
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

    <script>
            $(document).ready(function(){
                $("#IdTipoAnimal").change(function(){
                var racaSelect = $('#IdRaca');

                racaSelect.empty(); // limpa as opções anteriores
                racaSelect.append('<option value="">Carregando...</option>');
                    if ($(this).val()) {
                        $.get('/Animal/RecuperarRaca', { id: $(this).val() }, function (data) {
                            racaSelect.empty(); // limpa novamente
                            racaSelect.append('<option>Selecione uma raça</option>');
                            $.each(data, function (index, item) {
                                racaSelect.append($('<option>', {
                                    value: item.value,
                                    text: item.text
                                }));
                            });
                        });
                    } else {
                        racaSelect.empty();
                        racaSelect.append('<option>Selecione uma raça</option>');
                    }
                })

                $('form').submit(function (e) {
                    const fileInput = $('input[name="Foto"]');
                    const file = fileInput[0].files[0];

                    if (!file) {
                        fileInput.next('span.text-danger').text('Campo obrigatório!');
                        e.preventDefault();
                    } else {
                        fileInput.next('span.text-danger').text('');
                    }
                })

             })

    </script>
}

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
<script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>

