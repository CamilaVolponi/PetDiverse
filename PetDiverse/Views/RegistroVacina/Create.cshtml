@model PetDiverse.Models.RegistroVacinaViewModel

@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>

<h4>RegistroVacina</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <input asp-for="IdAnimal" type="hidden"/>
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="DataRegistro" class="control-label"></label>
                <input asp-for="DataRegistro" class="form-control" />
                <span asp-validation-for="DataRegistro" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="IdTipoVacina" class="control-label"></label>
                <select asp-for="IdTipoVacina" class ="form-control" asp-items="ViewBag.IdTipoVacina"><option>Selecione o tipo da vacina</option></select>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index" asp-route-idAnimal="@Model.IdAnimal">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
