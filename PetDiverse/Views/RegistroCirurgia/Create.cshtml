@model PetDiverse.Models.RegistroCirurgiaViewModel

@{
    ViewData["Title"] = "Registrar cirurgia";
}

<h2>Registrar cirurgia</h2>
<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <input asp-for="IdAnimal" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="row">
                <div class="col-md-9">
                    <div class="form-group row">
                        <label asp-for="DataRegistro" class="col-sm-5 control-label"></label>
                        <div class="col-sm-7">
                            <input asp-for="DataRegistro" type="date" class="form-control" />
                            <span asp-validation-for="DataRegistro" class="text-danger"></span>
                        </div>
                    </div>
                </div>
            </div>
            <br />
            <div class="row">
                <div class="col-md-9">
                    <div class="form-group row">
                        <label asp-for="IdTipoCirurgia" class="col-sm-5 control-label"></label>
                        <div class="col-sm-7">
                            <select asp-for="IdTipoCirurgia" class="form-control" asp-items="ViewBag.IdTipoCirurgia"><option value="">Selecione o tipo da cirurgia</option></select>
                            <span asp-validation-for="IdTipoCirurgia" class="text-danger"></span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="form-group mt-2">
                <a asp-action="Index" asp-route-idAnimal="IdAnimal" class="btn btn-cinza">Voltar a lista</a>
                <input type="submit" value="Criar" class="btn btn-roxo" />
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
