@model PetDiverse.Data.TipoAnimal

@{
    ViewData["Title"] = "Editar tipo de animal";
}

<h2>Editar tipo de animal</h2>

@* <h4>TipoAnimal</h4> *@
<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="row">
                <div class="col-md-7">
                    <div class="form-group row">
                        <label asp-for="Descricao" class="col-sm-5 control-label"></label>
                        <div class="col-sm-7">
                            <input asp-for="Descricao" class="form-control" />
                            <span asp-validation-for="Descricao" class="text-danger"></span>
                        </div>
                    </div>
                </div>
            </div>
            <br />
            <div class="form-group mt-2">
                <a asp-action="Index" class="btn btn-cinza">Voltar a lista</a>
                <input type="submit" value="Editar" class="btn btn-roxo" />
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
