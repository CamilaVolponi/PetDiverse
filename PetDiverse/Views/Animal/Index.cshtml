@model IEnumerable<PetDiverse.Data.Animal>

@{
    ViewData["Title"] = "Index";
}

<h1 class="text-center">Meus animais</h1>
<p>
    <a asp-action="Create" class="btn btn-roxo">+ Adicionar</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                Nome
            </th>
            <th>
                Idade
            </th>
            <th>
                Sexo biológico
            </th>
            <th>
                Porte
            </th>
            <th>
                Tipo de animal
            </th>
            <th>
                Raça
            </th>
            <th>
                Adotado
            </th>
            <th>
                Ações
            </th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                <a class="link-roxo" asp-action="Details" asp-route-id="@item.Id">@Html.DisplayFor(modelItem => item.Nome)</a>
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Idade) @item.ContagemIdade.ToString().ToLower()
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.SexoBiologico)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Porte)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.TipoAnimal.Descricao)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Raca.Descricao)
            </td>
            <td>
                @if (item.Adotado)
                {
                    <span>Adotado</span>
                }
                else
                {
                    <span>Ainda não foi adotado</span>
                }
            </td>
            <td>
                <div class="dropdown">
                    <button class="btn btn-secondary dropdown-roxo" type="button" id="dropdownMenuButton_@item.Id" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false"> </button>
                    <div class="dropdown-menu" aria-labelledby="dropdownMenuButton_@item.Id">
                        <a class="dropdown-item" asp-action="Edit" asp-route-id="@item.Id">Editar</a>
                        <a class="dropdown-item" asp-controller="RegistroVacina" asp-route-idAnimal="@item.Id">Vacinas</a>
                        <a class="dropdown-item" asp-controller="RegistroCirurgia" asp-route-idAnimal="@item.Id">Cirurgias</a>
                        <button class="dropdown-item btn-adocao" animal-id="@item.Id">Foi adotado</button>
                        <a class="dropdown-item" asp-action="Delete" asp-route-id="@item.Id">Excluir</a>
                    </div>
                </div>
            </td>
        </tr>
}
    </tbody>
</table>


<script src="https://code.jquery.com/jquery-3.5.1.slim.min.js" integrity="sha384-DfXdz2htPH0lsSSs5nCTpuj/zy4C+OGpamoFVy38MVBnE+IbbVYUew+OrCXaRkfj" crossorigin="anonymous"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.0/dist/js/bootstrap.bundle.min.js" integrity="sha384-Piv4xVNRyMGpqkS2by6br4gNJ7DXjqk09RmUpJ8jgGtD7zP9yug3goQfGII0yAns" crossorigin="anonymous"></script>
<script>
    $(document).ready(function(){
        $(".btn-adocao").click(function(){$.post('/Animal/Adotado', { id: $(this).attr("animal-id") }, function(){window.location.reload()})});
    })
</script>