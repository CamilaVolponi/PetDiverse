@model PetDiverse.Data.TipoAnimal

@{
    ViewData["Title"] = "Excluir tipo de animal";
}

<h2>Excluir tipo de animal</h2>

<h4>Tem certeza de que deseja excluir este tipo de animal?</h4>
<div>
    @* <h4>TipoAnimal</h4> *@
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Descricao)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Descricao)
        </dd>
    </dl>
    
    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <a asp-action="Index" class="btn btn-cinza">Voltar a lista</a>
        <input type="submit" value="Excluir" class="btn btn-danger" />
    </form>
</div>
