@model PetDiverse.Data.Cidade

@{
    ViewData["Title"] = "Excluir cidade";
}

<h2>Excluir cidade</h2>

<h4>Tem certeza de que deseja excluir esta cidade?</h4>
<div>
    @* <h4>Cidade</h4> *@
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Nome)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Nome)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Estado)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Estado.Nome)
        </dd>
    </dl>
    
    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <a asp-action="Index" class="btn btn-cinza">Voltar a lista</a>
        <input type="submit" value="Excluir" class="btn btn-danger" />
    </form>
</div>
