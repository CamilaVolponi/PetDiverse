@model IQueryable<PetDiverse.Data.Animal>

@{
    ViewData["Title"] = "Quero adotar!";
}
<div class="container mt-4">
    <div class="row">
        @foreach (var animal in Model){
        <div class="col-lg-3 col-md-4 col-sm-6 mb-4">
            <div class="card h-100">
                <img src="@animal.CaminhoFoto.Replace("wwwroot","")" class="bd-placeholder-img card-img-top" width="100" height="180" role="img" preserveAspectRatio="xMidYMid slice" focusable="false">    
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title">@animal.Nome</h5>
                        <p class="card-text mb-0">@animal.Idade</p>
                        <p class="card-text">@(animal.PessoaDoadora.Bairro.Nome + ", " + animal.PessoaDoadora.Bairro.Cidade.Nome + ", " + animal.PessoaDoadora.Bairro.Cidade.Estado.Sigla)</p>
                    <a href="#" class="btn btn-roxo mt-auto">Mais informações</a>
                </div>
            </div>
        </div>
        }
    </div>
</div>