@model PetDiverse.Data.Bairro

@{
    ViewData["Title"] = "Excluir bairro";
}

<h2>Excluir bairro</h2>

<h4>Tem certeza de que deseja excluir este bairro?</h4>
<div>
    @* <h4>Bairro</h4> *@
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Nome)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Nome)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Cidade)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Cidade.Nome)
        </dd>
    </dl>
    
    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <a asp-action="Index" class="btn btn-cinza">Voltar a lista</a>
        <input type="submit" value="Excluir" class="btn btn-danger" />
    </form>
</div>
