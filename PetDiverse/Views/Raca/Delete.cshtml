@model PetDiverse.Data.Raca

@{
    ViewData["Title"] = "Exclusão de raça";
}

<h2>Excluir de raça</h2>

<h4>Tem certeza de que deseja excluir esta raça?</h4>
<div>
    @* <h4>Raca</h4> *@
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Descricao)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Descricao)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.TipoAnimal)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.TipoAnimal.Descricao)
        </dd>
    </dl>
    
    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <a asp-action="Index" class="btn btn-cinza">Voltar a lista</a>
        <input type="submit" value="Excluir" class="btn btn-danger" />
    </form>
</div>
