@model PetDiverse.Data.Animal

@{
    ViewData["Title"] = "Excluir animal";
}

<h2>Excluir animal</h2>

<h4>Tem certeza de que deseja excluir este animal?</h4>
<div>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Nome)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Nome)
        </dd>
        <dt class = "col-sm-2">
            Descrição
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Descricao)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Idade)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Idade) @Model.ContagemIdade.ToString().ToLower()
        </dd>
        <dt class = "col-sm-2">
            Raça
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Raca.Descricao)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Porte)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Porte)
        </dd>
        <dt class = "col-sm-2">
            Tipo animal
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.TipoAnimal.Descricao)
        </dd>
    </dl>
    
    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <a asp-action="Index" class="btn btn-cinza">Voltar a lista</a>
        <input type="submit" value="Excluir" class="btn btn-danger" />
    </form>
</div>
