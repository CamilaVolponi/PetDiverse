@model IQueryable<PetDiverse.Data.Animal>

@{
    ViewData["Title"] = "Quero adotar!";
}
<div class="container">
    <div class="row">
        <h2>Escolha um novo amigo</h2>
    </div>
    <form method="get" asp-action="Index" asp-controller="" class="row g-2 mb-5 align-items-stretch">
        <div class="col-lg-2 col-md-4 col-sm-6">
            <select name="IdTipoAnimal" class="form-control" asp-items="ViewBag.IdTipoAnimal"><option value="">Selecione um tipo de animal</option></select>
        </div>
        <div class="col-lg-2 col-md-4 col-sm-6">
            <select id="IdEstado" name="IdEstado" class="form-control" asp-items="ViewBag.IdEstado"><option value="">Selecione um estado</option></select>
        </div>
        <div class="col-lg-2 col-md-4 col-sm-6">
            <select id="IdCidade" name="IdCidade" class="form-control" asp-items="ViewBag.IdCidade"><option value="">Selecione uma cidade</option></select>
        </div>
        <div class="col-lg-2 col-md-4 col-sm-6">
            <select id="IdBairro" name="IdBairro" class="form-control" asp-items="ViewBag.IdBairro"><option value="">Selecione um bairro</option></select>
        </div>
        <div class="col-lg-4 col-md-2 col-sm-12 d-flex">
            <button type="submit" class="btn btn-roxo w-100">Pesquisar</button>
        </div>
    </form>

    <div class="row">
        @foreach (var animal in Model)
        {
            <div class="col-lg-3 col-md-4 col-sm-6 mb-4">
                <div class="card h-100">
                    <img src="@animal.CaminhoFoto.Replace("wwwroot", "")" class="img-pet-card" width="100" height="250">
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@animal.Nome</h5>
                        <p class="card-text mb-0">@animal.Idade @animal.ContagemIdade.ToString().ToLower()</p>
                        <p class="card-text">
                            @(animal.PessoaDoadora.Bairro.Nome + ", " + animal.PessoaDoadora.Bairro.Cidade.Nome + ", " + animal.PessoaDoadora.Bairro.Cidade.Estado.Sigla)
                        </p>
                        <a class="btn btn-roxo mt-auto text-center" asp-controller="Animal" asp-action="Details" asp-route-id="@animal.Id"> Mais informações</a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        $(document).ready(function(){
            $("#IdEstado").change(function(){
                var cidadeSelect = $('#IdCidade');

                cidadeSelect.empty(); // limpa as opções anteriores
                cidadeSelect.append('<option value="">Carregando...</option>');
                if ($(this).val()) {
                    $.get('/Home/RecuperarCidades', { id: $(this).val() }, function (data) {
                        cidadeSelect.empty(); // limpa novamente
                        cidadeSelect.append('<option>Selecione uma cidade</option>');
                        $.each(data, function (index, item) {
                            cidadeSelect.append($('<option>', {
                                value: item.value,
                                text: item.text
                            }));
                        });
                    });
                } else {
                    cidadeSelect.empty();
                    cidadeSelect.append('<option>Selecione uma cidade</option>');
                }
            })

            $("#IdCidade").change(function(){
                var bairroSelect = $('#IdBairro');

                bairroSelect.empty(); // limpa as opções anteriores
                bairroSelect.append('<option value="">Carregando...</option>');

                if ($(this).val()) {
                    $.get('/Home/RecuperarBairros', { id: $(this).val() }, function (data) {
                        bairroSelect.empty(); // limpa novamente
                        bairroSelect.append('<option>Selecione um bairro</option>');
                        $.each(data, function (index, item) {
                            bairroSelect.append($('<option>', {
                                value: item.value,
                                text: item.text
                            }));
                        });
                    });
                } else {
                    bairroSelect.empty();
                    bairroSelect.append('<option>Selecione uma bairro</option>');
                }
            })

        });
    </script>

}